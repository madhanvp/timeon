generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  projects  Project[]
  entries   TimeEntry[]
}

model Project {
  id        String   @id @default(cuid())
  name      String
  color     String
  createdAt DateTime @default(now())

  userId    String
  user      User @relation(fields: [userId], references: [id])

  entries   TimeEntry[]
}

model TimeEntry {
  id          String   @id @default(cuid())
  description String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int?

  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id])

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
}