generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum OrganizationMemberRole {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ProjectType {
  SELF
  CLIENT
}

enum TaskStatus {
  TO_DO
  IN_PROGRESS
  COMPLETED
}

// ============================================================================
// CORE MODELS
// ============================================================================

/// User represents a TimeOn account.
/// A user can belong to multiple organizations via OrganizationMember.
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  organizationMemberships OrganizationMember[]
  organizationsCreated    Organization[]       @relation("OrganizationCreator")
  timeEntries             TimeEntry[]

  @@index([email])
}

/// Organization represents a workspace (company, team, or personal workspace).
/// Every user gets a default personal organization on signup.
/// Users can be invited to multiple organizations via OrganizationMember.
model Organization {
  id              String   @id @default(cuid())
  name            String
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  createdByUser User                 @relation("OrganizationCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  members       OrganizationMember[]
  clients       Client[]
  projects      Project[]
  timeEntries   TimeEntry[]

  @@index([createdByUserId])
}

/// OrganizationMember represents a user's membership in an organization.
/// Defines what actions a user can perform (OWNER/ADMIN/MANAGER/EMPLOYEE).
/// Enables collaboration and multi-org support.
model OrganizationMember {
  id             String                 @id @default(cuid())
  userId         String
  organizationId String
  role           OrganizationMemberRole
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  // Relationships
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

/// Client represents a customer/entity that owns projects.
/// Clients are organization-specific; each client belongs to exactly one organization.
/// Enables distinguishing client projects from internal/self projects.
model Client {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relationships
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]

  @@index([organizationId])
}

/// Project represents a grouping of tasks and time entries.
/// Projects can be SELF (internal) or CLIENT (owned by a client).
/// Every project belongs to exactly one organization.
model Project {
  id             String      @id @default(cuid())
  name           String
  color          String
  type           ProjectType @default(SELF)
  organizationId String
  clientId       String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  // Relationships
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tasks        Task[]
  timeEntries  TimeEntry[]

  @@index([organizationId])
  @@index([clientId])
  @@index([deletedAt])
}

/// Task represents a unit of work within a project.
/// Every task belongs to exactly one project (tasks cannot exist without a project).
/// Tasks have a status: TO_DO, IN_PROGRESS, or COMPLETED.
model Task {
  id        String     @id @default(cuid())
  title     String
  projectId String
  status    TaskStatus @default(TO_DO)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  // Relationships
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
}

/// TimeEntry represents a block of time tracked by a user.
/// TimeEntry is flexible:
///   - organizationId (required): Quick Start timer only needs org + user.
///   - projectId (optional): can be assigned later.
///   - taskId (optional): can be assigned later.
/// endTime NULL means the entry is still running.
/// duration is pre-computed; if NULL, can be calculated as (endTime - startTime).
model TimeEntry {
  id             String    @id @default(cuid())
  userId         String
  organizationId String
  projectId      String?
  taskId         String?
  description    String?
  startTime      DateTime
  endTime        DateTime?
  duration       Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relationships
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task         Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([projectId])
  @@index([taskId])
  @@index([startTime])
}

// ============================================================================
// FUTURE MODELS (Documented for reference, not yet implemented)
// ============================================================================

// ProjectMember: Restrict visibility/editing of projects to specific team members.
//   - id, projectId, userId, role (OWNER/EDITOR/VIEWER)
//   - Enables fine-grained project-level permissions.

// Invitation: Allow users to invite others to an organization.
//   - id, organizationId, email, token, expiresAt, createdByUserId
//   - Enables signup flow for multi-user organizations.

// Tag: Categorize time entries and tasks (future categorization feature).
//   - id, name, organizationId, color
//   - TimeEntry.tagId or many-to-many relationship.
//   - Enables flexible tagging for reporting/export.
